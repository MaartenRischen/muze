{
  "description": "selectScale(lipCorner, extraScaleMode) -> scale intervals",
  "cases": [
    { "input": { "lipCorner": 0.95, "extraScaleMode": null }, "expected": [0,2,4,6,7,9,11], "label": "very bright -> Lydian" },
    { "input": { "lipCorner": 0.81, "extraScaleMode": null }, "expected": [0,2,4,6,7,9,11], "label": "bright -> Lydian" },
    { "input": { "lipCorner": 0.70, "extraScaleMode": null }, "expected": [0,2,4,5,7,9,11], "label": "happy -> Ionian" },
    { "input": { "lipCorner": 0.50, "extraScaleMode": null }, "expected": [0,2,4,5,7,9,10], "label": "neutral-bright -> Mixolydian" },
    { "input": { "lipCorner": 0.30, "extraScaleMode": null }, "expected": [0,2,3,5,7,9,10], "label": "neutral -> Dorian" },
    { "input": { "lipCorner": 0.10, "extraScaleMode": null }, "expected": [0,2,3,5,7,8,10], "label": "sad -> Aeolian" },
    { "input": { "lipCorner": -0.50, "extraScaleMode": null }, "expected": [0,1,3,5,7,8,10], "label": "very dark -> Phrygian" },
    { "input": { "lipCorner": 0.00, "extraScaleMode": null }, "expected": [0,2,3,5,7,8,10], "label": "edge: exactly 0 -> Aeolian" },
    { "input": { "lipCorner": 0.20, "extraScaleMode": null }, "expected": [0,2,3,5,7,8,10], "label": "edge: exactly 0.20 -> Aeolian" },
    { "input": { "lipCorner": 0.50, "extraScaleMode": "blues" }, "expected": [0,3,5,6,7,10], "label": "extra mode overrides face: blues" },
    { "input": { "lipCorner": 0.90, "extraScaleMode": "hirajoshi" }, "expected": [0,2,3,7,8], "label": "extra mode overrides face: hirajoshi" },
    { "input": { "lipCorner": 0.50, "extraScaleMode": "nonexistent" }, "expected": [0,2,3,5,7,9,10], "label": "unknown extra mode -> Dorian fallback" }
  ]
}
