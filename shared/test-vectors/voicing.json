{
  "description": "getPadVoicing(root, scale, degree) -> [noteStr x4] and getArpNotes(scale, root, degree, octaveRange) -> [noteStr...]",
  "padVoicing": [
    { "input": { "root": 60, "scale": [0,2,3,5,7,9,10], "degree": 0 }, "expected": ["C3", "D#4", "G4", "A#4"], "label": "Dorian root chord" },
    { "input": { "root": 60, "scale": [0,2,4,5,7,9,11], "degree": 0 }, "expected": ["C3", "E4", "G4", "B4"], "label": "Ionian root chord (Cmaj7)" },
    { "input": { "root": 60, "scale": [0,2,3,5,7,9,10], "degree": 1 }, "expected": ["D3", "F4", "A4", "C5"], "label": "Dorian ii chord" },
