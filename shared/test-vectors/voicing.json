  ],
  "arpNotes": [
    { "input": { "scale": [0,2,3,5,7,9,10], "root": 60, "degree": 0, "octaveRange": 2 }, "expected": ["C4", "D#4", "G4", "A#4", "C5", "D#5", "G5", "A#5"], "label": "Dorian root 2oct" },
    { "input": { "scale": [0,2,4,5,7,9,11], "root": 60, "degree": 0, "octaveRange": 1 }, "expected": ["C4", "E4", "G4", "B4"], "label": "Ionian root 1oct" }
  ]
