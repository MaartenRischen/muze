{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jammerman State",
  "description": "Runtime state object shared across platforms",
  "type": "object",
  "properties": {
    "mouthOpenness": { "type": "number", "minimum": 0, "maximum": 1 },
    "lipCorner": { "type": "number", "minimum": -1, "maximum": 1 },
    "browHeight": { "type": "number", "minimum": 0, "maximum": 1 },
    "eyeOpenness": { "type": "number", "minimum": 0, "maximum": 1 },
    "mouthWidth": { "type": "number", "minimum": 0, "maximum": 1 },
    "headPitch": { "type": "number" },
    "headYaw": { "type": "number" },
    "headRoll": { "type": "number" },
    "faceDetected": { "type": "boolean" },
    "handPresent": { "type": "boolean" },
    "handY": { "type": "number", "minimum": 0, "maximum": 1 },
    "handX": { "type": "number", "minimum": 0, "maximum": 1 },
    "handOpen": { "type": "boolean" },
    "currentScale": { "type": "array", "items": { "type": "integer" } },
    "melodyNote": { "type": ["integer", "null"] },
    "chordIndex": { "type": "integer", "minimum": 0 },
    "autoRhythm": { "type": "boolean" },
    "modeFrozen": { "type": "boolean" },
    "portamentoMode": { "type": "boolean" },
    "audioReady": { "type": "boolean" },
    "currentModeName": { "type": "string" },
    "rootOffset": { "type": "integer", "minimum": 0, "maximum": 11 },
    "bpm": { "type": "integer", "minimum": 40, "maximum": 200 },
    "swing": { "type": "integer", "minimum": 0, "maximum": 100 },
    "arpPatternIdx": { "type": "integer" },
    "arpNoteValueIdx": { "type": "integer" },
    "arp2PatternIdx": { "type": "integer" },
    "arp2NoteValueIdx": { "type": "integer" },
    "presetIdx": { "type": "integer" },
    "extraScaleMode": { "type": ["string", "null"] },
    "latencyMode": { "type": "string", "enum": ["low", "balanced", "safe"] }
  }
}
